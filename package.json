{
  "name": "tactual",
  "version": "0.5.0",
  "mcpName": "io.github.tactual-dev/tactual",
  "description": "Screen-reader navigation cost analyzer. Measures how hard it is for AT users to discover, reach, and operate web content.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tactual": "dist/cli/index.js",
    "tactual-mcp": "dist/mcp/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./playwright": {
      "import": "./dist/playwright/index.js",
      "types": "./dist/playwright/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./calibration": {
      "import": "./dist/calibration/index.js",
      "types": "./dist/calibration/index.d.ts"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:benchmark": "vitest run src/benchmark/benchmark.test.ts",
    "test:shard": "node scripts/vitest-shards.mjs",
    "test:shards": "node scripts/vitest-shards.mjs --all",
    "test:release": "node scripts/test-release.mjs",
    "benchmark:known-pages": "node scripts/known-pages-corpus.mjs --build",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "calibrate": "node scripts/aria-at-calibrate.mjs",
    "calibration:corpus": "node scripts/calibration-corpus.mjs audit",
    "calibration:matrix": "node scripts/calibration-matrix.mjs",
    "calibration:import-nvda": "node scripts/calibration-corpus.mjs import-nvda-batch",
    "smoke:pack": "node scripts/pack-smoke.mjs",
    "smoke:release": "node scripts/release-smoke.mjs",
    "nvda:vm:observe": "node scripts/nvda-vm-observe.mjs",
    "nvda:vm:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/nvda-vm-preflight.ps1",
    "nvda:vm:sequence": "node scripts/nvda-vm-sequence.mjs",
    "nvda:vm:guest-bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/nvda-vm-guest-bootstrap.ps1",
    "nvda:vm:batch-calibrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/nvda-vm-batch-calibrate.ps1",
    "nvda:vm:batch-report": "node scripts/nvda-vm-batch-report.mjs",
    "nvda:vm:host-calibrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/nvda-vm-host-calibrate.ps1",
    "nvda:vm:host-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/nvda-vm-host-smoke.ps1",
    "release:drift": "node scripts/release-drift.mjs",
    "release:verify": "npm run test:release",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "screen-reader",
    "assistive-technology",
    "navigation",
    "playwright",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "wcag",
    "aria",
    "sarif"
  ],
  "author": "Ben Matar",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tactual-dev/tactual.git"
  },
  "homepage": "https://github.com/tactual-dev/tactual#readme",
  "bugs": {
    "url": "https://github.com/tactual-dev/tactual/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@guidepup/virtual-screen-reader": "^0.32.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "playwright": "^1.61.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@guidepup/virtual-screen-reader": "^0.32.1",
    "jsdom": "^29.1.1"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
