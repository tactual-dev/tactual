{
  "name": "tactual",
  "version": "0.4.1",
  "mcpName": "io.github.tactual-dev/tactual",
  "description": "Screen-reader navigation cost analyzer. Measures how hard it is for AT users to discover, reach, and operate web content.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tactual": "./dist/cli/index.js",
    "tactual-mcp": "./dist/mcp/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./playwright": {
      "import": "./dist/playwright/index.js",
      "types": "./dist/playwright/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./calibration": {
      "import": "./dist/calibration/index.js",
      "types": "./dist/calibration/index.d.ts"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:benchmark": "vitest run src/benchmark/benchmark.test.ts",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "calibrate": "node scripts/aria-at-calibrate.mjs",
    "smoke:pack": "node scripts/pack-smoke.mjs",
    "release:verify": "npm run typecheck && npm run lint && npm test && npm run test:coverage && npm run test:benchmark && npm audit --omit=dev && npm run calibrate && npm run smoke:pack",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "screen-reader",
    "assistive-technology",
    "navigation",
    "playwright",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "wcag",
    "aria",
    "sarif"
  ],
  "author": "Ben Matar",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tactual-dev/tactual.git"
  },
  "homepage": "https://github.com/tactual-dev/tactual#readme",
  "bugs": {
    "url": "https://github.com/tactual-dev/tactual/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@guidepup/virtual-screen-reader": "^0.32.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@guidepup/virtual-screen-reader": "^0.32.1",
    "jsdom": "^29.0.2"
  }
}
